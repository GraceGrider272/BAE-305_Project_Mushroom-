// Load external libraries
#include <Wire.h>
#include <Servo.h>
#include <Adafruit_VL53L0X.h>

Servo servo1;
Servo servo2;

Adafruit_VL53L0X lox1 = Adafruit_VL53L0X();      // Edit this to suit our specific needs
Adafruit_VL53L0X lox2 = Adafruit_VL53L0X();

// Creates a constant name for this value
#define ServoControl1 2 // Connects to pin 2
#define ServoControl2 3 // Connects to pin 3

int servoPin1 = 9;
int servoPin2 = 10;

int openAngle = 90;
int closedAngle = 0;

void setup() { // Initialization

  Serial.begin(9600);
  Wire.begin();

  servo1.attach(servoPin1);
  servo2.attach(servoPin2);

  servo1.write(closedAngle);
  servo2.write(closedAngle);

  pinMode(ServoControl1, OUTPUT);  // Connects to pins
  pinMode(ServoControl2, OUTPUT);

  digitalWrite(ServoControl1, LOW);  // Connects to power
  digitalWrite(ServoControl2, LOW);
  delay(10);

  // Start first sensor
  digitalWrite(ServoControl1, HIGH);
  delay(10);
  if (!lox1.begin(0x30)) {
    Serial.println("Sensor 1 failed");
    while (1);
  }

  // Start second sensor
  digitalWrite(ServoControl2, HIGH);
  delay(10);
  if (!lox2.begin(0x31)) {
    Serial.println("Sensor 2 failed");
    while (1);
  }

  Serial.println("Both sensors ready");
}

void loop() {    // Loop of measuring data starts

  VL53L0X_RangingMeasurementData_t measure1;  // Again, can change this sensor name later
  VL53L0X_RangingMeasurementData_t measure2;

  lox1.rangingTest(&measure1, false);
  lox2.rangingTest(&measure2, false);

  int distance1 = measure1.RangeMilliMeter / 10;
  int distance2 = measure2.RangeMilliMeter / 10;

  Serial.print("Sensor1: ");
  Serial.print(distance1);
  Serial.print(" cm   ");

  Serial.print("Sensor2: ");
  Serial.print(distance2);
  Serial.println(" cm");

  // Servo 1: Controls open/ close
  if (distance1 < 50) {
    servo1.write(openAngle);
  } else {
    servo1.write(closedAngle);
  }

  // Servo 2: Controls open/ close
  if (distance2 < 50) {
    servo2.write(openAngle);
  } else {
    servo2.write(closedAngle);
  }

  delay(100);
}
