#include <Wire.h>
#include <Servo.h>
#include <Adafruit_VL53L0X.h>

Servo servo1;
Servo servo2;
Adafruit_VL53L0X lox1 = Adafruit_VL53L0X();

#define ServoControl1 2

int servoPin1 = 9;
int servoPin2 = 10;
int activeAngle = 45;
int closedAngle = 0;

unsigned long servo1StartTime = 0;
bool servo1IsActive = false;
long servo1Duration = 10000;

unsigned long servo2StartTime = 0;
bool servo2IsActive = false;
long servo2Duration = 10000;

bool modeSelected = false;
bool sequenceStarted = false;
bool refillPrinted = false;

void setup() {
  Serial.begin(9600);
  Wire.begin();

  servo1.attach(servoPin1);
  servo2.attach(servoPin2);
  servo1.write(closedAngle);
  servo2.write(closedAngle);

  pinMode(ServoControl1, OUTPUT);
  digitalWrite(ServoControl1, HIGH);
  delay(10);

  if (!lox1.begin(0x30)) {
    Serial.println("Sensor 1 fail!");
    while (1);
  }

  // --- NEW SENSITIVITY FIX ---
  // Increase timing budget to 200ms (standard is 33ms). 
  // This allows the sensor to detect dark/non-reflective objects much better.
  lox1.setMeasurementTimingBudgetMicroSeconds(200000); 

  displayMenu();
}

void loop() {
  unsigned long currentMillis = millis();

  if (!modeSelected) {
    if (Serial.available() > 0) {
      char choice = Serial.read();
      handleMenu(choice);
    }
  } 
  else if (modeSelected && !sequenceStarted) {
    VL53L0X_RangingMeasurementData_t measure1;
    lox1.rangingTest(&measure1, false);

    int dist1 = measure1.RangeMilliMeter / 10;

    Serial.print("Dist: "); Serial.print(dist1); Serial.print("cm | Status: "); Serial.println(measure1.RangeStatus);

    // LOGIC ADJUSTMENT:
    // If status is 0 (Perfect) OR 1/2 (Warning but usually valid on dark surfaces)
    if (dist1 > 0 && dist1 <= 20 && (measure1.RangeStatus == 0 || measure1.RangeStatus == 1 || measure1.RangeStatus == 2)) {
      refillPrinted = false;
      startSequence(currentMillis);
    } 
    else if (dist1 > 20 || dist1 == 0 || measure1.RangeStatus == 4) {
      if (!refillPrinted) {
        Serial.println(">>> REFILL REQUIRED.");
        refillPrinted = true;
      }
    }
  }

  if (servo1IsActive && (currentMillis - servo1StartTime >= servo1Duration)) {
    servo1.write(closedAngle);
    servo1IsActive = false;
    checkIfBothFinished();
  }

  if (servo2IsActive && (currentMillis - servo2StartTime >= servo2Duration)) {
    servo2.write(closedAngle);
    servo2IsActive = false;
    checkIfBothFinished();
  }
}

void displayMenu() {
  Serial.println("\n--- MODE SELECT ---");
  Serial.println("1: 50/50 | 2: 66/33 | 3: 33/66");
}

void handleMenu(char choice) {
  if (choice == '1' || choice == '2' || choice == '3') {
    if (choice == '1') { servo1Duration = 10000; servo2Duration = 10000; }
    else if (choice == '2') { servo1Duration = 10000; servo2Duration = 5000; }
    else if (choice == '3') { servo1Duration = 5000; servo2Duration = 10000; }
    Serial.println("Armed.");
    modeSelected = true;
    refillPrinted = false;
  }
}

void startSequence(unsigned long now) {
  Serial.println("Triggered!");
  servo1.write(activeAngle);
  servo2.write(activeAngle);
  servo1StartTime = now;
  servo2StartTime = now;
  servo1IsActive = true;
  servo2IsActive = true;
  sequenceStarted = true;
}

void checkIfBothFinished() {
  if (!servo1IsActive && !servo2IsActive && sequenceStarted) {
    modeSelected = false;
    sequenceStarted = false;
    displayMenu();
  }
}
